<Window x:Class="VendingMachineDesktop.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:local="clr-namespace:VendingMachineDesktop.Utilities.Converters"
        Title="ООО Торговые Автоматы" Height="768" Width="1366"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">

    <Window.Resources>
        <!-- Converter for sidebar width -->
        <local:BoolToWidthConverter x:Key="BoolToWidthConverter"/>
        <local:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="20,16">
            <Grid MinHeight="48">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left: Company Logo -->
                <Image Grid.Column="0"
                       Source="/Resources/CompanyLogo.png"
                       Height="50"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Left"
                       Stretch="Uniform"
                       RenderOptions.BitmapScalingMode="Fant"
                       SnapsToDevicePixels="True"
                       UseLayoutRounding="True"
                       Margin="0,0,20,0"/>

                <!-- Center: Breadcrumb -->
                <TextBlock x:Name="BreadcrumbText"
                          Grid.Column="2"
                          Text="Главная"
                          FontSize="14"
                          Foreground="#757575"
                          VerticalAlignment="Center"
                          HorizontalAlignment="Right"
                          Margin="0,0,20,0"/>

                <!-- Right: User Menu with Flag -->
                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Russian Flag -->
                    <Border Width="24" Height="16" Margin="0,0,12,0" VerticalAlignment="Center"
                            BorderBrush="#CCCCCC" BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Rectangle Fill="White" Grid.Row="0"/>
                            <Rectangle Fill="#0039A6" Grid.Row="1"/>
                            <Rectangle Fill="#D52B1E" Grid.Row="2"/>
                        </Grid>
                    </Border>

                    <Button x:Name="UserMenuButton" Click="UserMenuButton_Click"
                           Background="Transparent" BorderThickness="0"
                           Padding="10,12" Cursor="Hand"
                           VerticalAlignment="Center"
                           VerticalContentAlignment="Center"
                           Height="Auto"
                           MinHeight="52">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <!-- Avatar -->
                            <Grid Width="36" Height="36" Margin="0,0,12,0" VerticalAlignment="Center">
                                <Ellipse Width="36" Height="36" Fill="#1976D2"/>
                                <TextBlock Text="{Binding UserInitial}"
                                          FontSize="15" Foreground="White"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          FontWeight="SemiBold"/>
                            </Grid>
                            <!-- Name and Role -->
                            <StackPanel Margin="0,0,10,0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding UserFullName}"
                                          FontSize="14"
                                          Foreground="#424242"
                                          FontWeight="SemiBold"
                                          TextTrimming="CharacterEllipsis"
                                          MaxWidth="140"
                                          LineHeight="18"/>
                                <TextBlock Text="{Binding UserRole}"
                                          FontSize="12"
                                          Foreground="#757575"
                                          TextTrimming="CharacterEllipsis"
                                          MaxWidth="140"
                                          LineHeight="16"/>
                            </StackPanel>
                            <!-- Arrow -->
                            <materialDesign:PackIcon Kind="ChevronDown"
                                                    Width="20" Height="20"
                                                    Foreground="#757575"
                                                    VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content with Sidebar -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Sidebar Menu (Dark) -->
            <Border Grid.Column="0"
                    Background="#2C3E50"
                    Width="{Binding IsPaneOpen, Converter={StaticResource BoolToWidthConverter}, ConverterParameter=250}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <!-- Logo Area с кнопкой сворачивания -->
                        <Border Height="64" Background="#34495E">
                            <Grid>
                                <!-- Развёрнутое меню -->
                                <Grid Visibility="{Binding IsPaneOpen, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0"
                                               Orientation="Horizontal"
                                               HorizontalAlignment="Left"
                                               VerticalAlignment="Center"
                                               Margin="15,0,0,0">
                                        <materialDesign:PackIcon Kind="CoffeeToGo"
                                                                Width="28" Height="28"
                                                                Foreground="White"
                                                                Margin="0,0,10,0"/>
                                        <TextBlock Text="Навигация"
                                                  FontSize="16"
                                                  FontWeight="SemiBold"
                                                  Foreground="White"
                                                  VerticalAlignment="Center"/>
                                    </StackPanel>

                                    <Button Grid.Column="1"
                                            Command="{Binding TogglePaneCommand}"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Padding="10"
                                            Margin="0,0,5,0"
                                            Cursor="Hand"
                                            VerticalAlignment="Center">
                                        <materialDesign:PackIcon Kind="Menu" Width="24" Height="24" Foreground="White"/>
                                    </Button>
                                </Grid>

                                <!-- Свёрнутое меню -->
                                <Button Command="{Binding TogglePaneCommand}"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Cursor="Hand"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsPaneOpen}" Value="False">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <materialDesign:PackIcon Kind="Menu" Width="24" Height="24" Foreground="White"/>
                                </Button>
                            </Grid>
                        </Border>

                        <!-- Navigation Menu -->
                        <StackPanel Margin="0,10,0,0">
                            <!-- Главная -->
                            <Button x:Name="DashboardButton"
                                   Click="MenuButton_Click"
                                   Tag="Dashboard"
                                   Background="Transparent"
                                   BorderThickness="0"
                                   HorizontalContentAlignment="Left"
                                   Padding="19,12"
                                   Cursor="Hand"
                                   ToolTip="Главная">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#34495E"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Home"
                                                            Width="22" Height="22"
                                                            Foreground="White"/>
                                    <TextBlock Text="Главная"
                                              FontSize="14"
                                              Foreground="White"
                                              VerticalAlignment="Center"
                                              Margin="15,0,0,0"
                                              Visibility="{Binding IsPaneOpen, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                </StackPanel>
                            </Button>

                            <!-- Монитор ТА -->
                            <Button x:Name="MonitorButton"
                                   Click="MenuButton_Click"
                                   Tag="Monitor"
                                   Background="Transparent"
                                   BorderThickness="0"
                                   HorizontalContentAlignment="Left"
                                   Padding="19,12"
                                   Cursor="Hand"
                                   ToolTip="Монитор ТА">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#34495E"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Monitor"
                                                            Width="22" Height="22"
                                                            Foreground="White"/>
                                    <TextBlock Text="Монитор ТА"
                                              FontSize="14"
                                              Foreground="White"
                                              VerticalAlignment="Center"
                                              Margin="15,0,0,0"
                                              Visibility="{Binding IsPaneOpen, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                </StackPanel>
                            </Button>

                            <!-- Детальные отчеты -->
                            <Button x:Name="ReportsButton"
                                   Click="MenuButton_Click"
                                   Tag="Reports"
                                   Background="Transparent"
                                   BorderThickness="0"
                                   HorizontalContentAlignment="Left"
                                   Padding="19,12"
                                   Cursor="Hand"
                                   ToolTip="Детальные отчеты"
                                   Visibility="{Binding CanAccessReports, Converter={StaticResource BoolToVisibilityConverter}}">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#34495E"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="ChartLine"
                                                            Width="22" Height="22"
                                                            Foreground="White"/>
                                    <TextBlock Text="Детальные отчеты"
                                              FontSize="14"
                                              Foreground="White"
                                              VerticalAlignment="Center"
                                              Margin="15,0,0,0"
                                              Visibility="{Binding IsPaneOpen, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                </StackPanel>
                            </Button>

                            <!-- Учет ТМЦ -->
                            <Button x:Name="InventoryButton"
                                   Click="MenuButton_Click"
                                   Tag="Inventory"
                                   Background="Transparent"
                                   BorderThickness="0"
                                   HorizontalContentAlignment="Left"
                                   Padding="19,12"
                                   Cursor="Hand"
                                   ToolTip="Учет ТМЦ"
                                   Visibility="{Binding CanAccessInventory, Converter={StaticResource BoolToVisibilityConverter}}">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#34495E"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Package"
                                                            Width="22" Height="22"
                                                            Foreground="White"/>
                                    <TextBlock Text="Учет ТМЦ"
                                              FontSize="14"
                                              Foreground="White"
                                              VerticalAlignment="Center"
                                              Margin="15,0,0,0"
                                              Visibility="{Binding IsPaneOpen, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                </StackPanel>
                            </Button>

                            <!-- Администрирование - при свернутом меню показываем только иконку -->
                            <StackPanel Visibility="{Binding CanAccessAdmin, Converter={StaticResource BoolToVisibilityConverter}}">
                                <!-- Кнопка-заголовок Администрирование -->
                                <Button x:Name="AdminExpandButton"
                                       Click="AdminExpandButton_Click"
                                       Background="Transparent"
                                       BorderThickness="0"
                                       HorizontalContentAlignment="Left"
                                       Padding="19,12"
                                       Cursor="Hand"
                                       ToolTip="Администрирование">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#34495E"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <materialDesign:PackIcon Kind="Cog"
                                                                Width="22" Height="22"
                                                                Foreground="White"
                                                                Grid.Column="0"/>
                                        <TextBlock Text="Администрирование"
                                                  FontSize="14"
                                                  Foreground="White"
                                                  VerticalAlignment="Center"
                                                  Margin="15,0,0,0"
                                                  Grid.Column="1"
                                                  Visibility="{Binding IsPaneOpen, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                        <materialDesign:PackIcon x:Name="AdminExpandIcon"
                                                                Kind="ChevronDown"
                                                                Width="18" Height="18"
                                                                Foreground="White"
                                                                Grid.Column="2"
                                                                Margin="10,0,0,0"
                                                                Visibility="{Binding IsPaneOpen, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                    </Grid>
                                </Button>

                                <!-- Подменю Администрирования -->
                                <StackPanel x:Name="AdminSubMenu"
                                           Background="#1A252F"
                                           Visibility="Collapsed">
                                    <!-- Торговые автоматы -->
                                    <Button Click="MenuButton_Click"
                                           Tag="VendingMachines"
                                           Background="Transparent"
                                           BorderThickness="0"
                                           HorizontalContentAlignment="Left"
                                           Cursor="Hand"
                                           ToolTip="Торговые автоматы">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="Padding" Value="57,10"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#34495E"/>
                                                    </Trigger>
                                                    <DataTrigger Binding="{Binding IsPaneOpen}" Value="False">
                                                        <Setter Property="Padding" Value="19,10"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="StorefrontOutline"
                                                                    Width="18" Height="18"
                                                                    Foreground="White">
                                                <materialDesign:PackIcon.Style>
                                                    <Style TargetType="materialDesign:PackIcon">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsPaneOpen}" Value="False">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </materialDesign:PackIcon.Style>
                                            </materialDesign:PackIcon>
                                            <TextBlock Text="Торговые автоматы"
                                                      FontSize="13"
                                                      Foreground="White"
                                                      Visibility="{Binding IsPaneOpen, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                        </StackPanel>
                                    </Button>

                                    <!-- Компании -->
                                    <Button Click="MenuButton_Click"
                                           Tag="Companies"
                                           Background="Transparent"
                                           BorderThickness="0"
                                           HorizontalContentAlignment="Left"
                                           Cursor="Hand"
                                           ToolTip="Компании"
                                           Visibility="{Binding CanAccessCompanies, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="Padding" Value="57,10"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#34495E"/>
                                                    </Trigger>
                                                    <DataTrigger Binding="{Binding IsPaneOpen}" Value="False">
                                                        <Setter Property="Padding" Value="19,10"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="Domain"
                                                                    Width="18" Height="18"
                                                                    Foreground="White">
                                                <materialDesign:PackIcon.Style>
                                                    <Style TargetType="materialDesign:PackIcon">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsPaneOpen}" Value="False">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </materialDesign:PackIcon.Style>
                                            </materialDesign:PackIcon>
                                            <TextBlock Text="Компании"
                                                      FontSize="13"
                                                      Foreground="White"
                                                      Visibility="{Binding IsPaneOpen, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                        </StackPanel>
                                    </Button>

                                    <!-- Пользователи -->
                                    <Button Click="MenuButton_Click"
                                           Tag="Users"
                                           Background="Transparent"
                                           BorderThickness="0"
                                           HorizontalContentAlignment="Left"
                                           Cursor="Hand"
                                           ToolTip="Пользователи"
                                           Visibility="{Binding CanAccessUsers, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="Padding" Value="57,10"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#34495E"/>
                                                    </Trigger>
                                                    <DataTrigger Binding="{Binding IsPaneOpen}" Value="False">
                                                        <Setter Property="Padding" Value="19,10"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="AccountGroup"
                                                                    Width="18" Height="18"
                                                                    Foreground="White">
                                                <materialDesign:PackIcon.Style>
                                                    <Style TargetType="materialDesign:PackIcon">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsPaneOpen}" Value="False">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </materialDesign:PackIcon.Style>
                                            </materialDesign:PackIcon>
                                            <TextBlock Text="Пользователи"
                                                      FontSize="13"
                                                      Foreground="White"
                                                      Visibility="{Binding IsPaneOpen, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                        </StackPanel>
                                    </Button>

                                    <!-- Модемы -->
                                    <Button Click="MenuButton_Click"
                                           Tag="Modems"
                                           Background="Transparent"
                                           BorderThickness="0"
                                           HorizontalContentAlignment="Left"
                                           Cursor="Hand"
                                           ToolTip="Модемы">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="Padding" Value="57,10"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#34495E"/>
                                                    </Trigger>
                                                    <DataTrigger Binding="{Binding IsPaneOpen}" Value="False">
                                                        <Setter Property="Padding" Value="19,10"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="RouterWireless"
                                                                    Width="18" Height="18"
                                                                    Foreground="White">
                                                <materialDesign:PackIcon.Style>
                                                    <Style TargetType="materialDesign:PackIcon">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsPaneOpen}" Value="False">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </materialDesign:PackIcon.Style>
                                            </materialDesign:PackIcon>
                                            <TextBlock Text="Модемы"
                                                      FontSize="13"
                                                      Foreground="White"
                                                      Visibility="{Binding IsPaneOpen, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                        </StackPanel>
                                    </Button>

                                    <!-- Контракты -->
                                    <Button Click="MenuButton_Click"
                                           Tag="Contracts"
                                           Background="Transparent"
                                           BorderThickness="0"
                                           HorizontalContentAlignment="Left"
                                           Cursor="Hand"
                                           ToolTip="Контракты"
                                           Visibility="{Binding CanAccessContracts, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="Padding" Value="57,10"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#34495E"/>
                                                    </Trigger>
                                                    <DataTrigger Binding="{Binding IsPaneOpen}" Value="False">
                                                        <Setter Property="Padding" Value="19,10"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="FileDocumentOutline"
                                                                    Width="18" Height="18"
                                                                    Foreground="White">
                                                <materialDesign:PackIcon.Style>
                                                    <Style TargetType="materialDesign:PackIcon">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsPaneOpen}" Value="False">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </materialDesign:PackIcon.Style>
                                            </materialDesign:PackIcon>
                                            <TextBlock Text="Контракты"
                                                      FontSize="13"
                                                      Foreground="White"
                                                      Visibility="{Binding IsPaneOpen, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Content Area -->
            <Frame x:Name="ContentFrame"
                  Grid.Column="1"
                  NavigationUIVisibility="Hidden"
                  Background="#F5F5F5"
                  Margin="0"/>
        </Grid>

        <!-- User Menu Dropdown Popup (at root level to avoid clipping) -->
        <Popup x:Name="UserMenuPopup"
               PlacementTarget="{Binding ElementName=UserMenuButton}"
               Placement="Bottom"
               StaysOpen="False"
               AllowsTransparency="True"
               HorizontalOffset="0"
               VerticalOffset="4">
            <Border Background="White"
                   BorderBrush="#E0E0E0"
                   BorderThickness="1"
                   CornerRadius="4"
                   Padding="0">
                <Border.Effect>
                    <DropShadowEffect Color="#40000000"
                                     Direction="270"
                                     ShadowDepth="4"
                                     BlurRadius="12"
                                     Opacity="0.3"/>
                </Border.Effect>
                <StackPanel Width="220">
                    <Button Click="MyProfileButton_Click"
                           Background="Transparent"
                           BorderThickness="0"
                           HorizontalContentAlignment="Left"
                           Padding="16,12"
                           Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#F5F5F5"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Account"
                                                    Width="20" Height="20"
                                                    Margin="0,0,12,0"
                                                    Foreground="#757575"/>
                            <TextBlock Text="Мой профиль" FontSize="14" Foreground="#424242"/>
                        </StackPanel>
                    </Button>
                    <Separator Margin="8,0"/>
                    <Button Click="MySessionsButton_Click"
                           Background="Transparent"
                           BorderThickness="0"
                           HorizontalContentAlignment="Left"
                           Padding="16,12"
                           Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#F5F5F5"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Lock"
                                                    Width="20" Height="20"
                                                    Margin="0,0,12,0"
                                                    Foreground="#757575"/>
                            <TextBlock Text="Мои сессии" FontSize="14" Foreground="#424242"/>
                        </StackPanel>
                    </Button>
                    <Separator Margin="8,0"/>
                    <Button Click="LogoutButton_Click"
                           Background="Transparent"
                           BorderThickness="0"
                           HorizontalContentAlignment="Left"
                           Padding="16,12"
                           Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#F5F5F5"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Logout"
                                                    Width="20" Height="20"
