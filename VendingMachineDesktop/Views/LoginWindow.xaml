<Window x:Class="VendingMachineDesktop.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Вход в систему - ООО Торговые Автоматы"
        Height="620" Width="450"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F5F5F5">

    <Grid>
        <!-- Logo and Company Name -->
        <StackPanel VerticalAlignment="Top" Margin="0,30,0,0">
            <Border Width="70" Height="70"
                    Background="#1976D2"
                    CornerRadius="35"
                    Margin="0,0,0,15">
                <TextBlock Text="ТА"
                          FontSize="28"
                          FontWeight="Bold"
                          Foreground="White"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"/>
            </Border>

            <TextBlock Text="ООО Торговые Автоматы"
                      FontSize="20"
                      FontWeight="Bold"
                      HorizontalAlignment="Center"
                      Foreground="#212121"
                      Margin="0,0,0,5"/>
        </StackPanel>

        <!-- Login Form -->
        <Border Margin="40,160,40,30"
                Background="White"
                CornerRadius="8"
                VerticalAlignment="Stretch">
            <Border.Effect>
                <DropShadowEffect Color="#888888" BlurRadius="10" ShadowDepth="2" Opacity="0.3"/>
            </Border.Effect>

            <StackPanel Margin="28,24,28,24">
                <TextBlock Text="Личный кабинет. Главная"
                          FontSize="18"
                          FontWeight="SemiBold"
                          HorizontalAlignment="Center"
                          Foreground="#424242"
                          Margin="0,0,0,20"/>

                <!-- Email -->
                <TextBlock Text="Email" FontSize="12" Foreground="#666" Margin="0,0,0,4"/>
                <TextBox x:Name="EmailTextBox"
                        Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                        FontSize="14"
                        Padding="8"
                        BorderBrush="#CCCCCC"
                        BorderThickness="1"
                        Margin="0,0,0,15"/>

                <!-- Password -->
                <TextBlock Text="Пароль" FontSize="12" Foreground="#666" Margin="0,0,0,4"/>
                <PasswordBox x:Name="PasswordBox"
                            PasswordChanged="PasswordBox_PasswordChanged"
                            FontSize="14"
                            Padding="8"
                            BorderBrush="#CCCCCC"
                            BorderThickness="1"
                            Margin="0,0,0,15"/>

                <!-- Error Message -->
                <TextBlock Text="{Binding ErrorMessage}"
                          Foreground="#D32F2F"
                          FontSize="12"
                          Margin="0,0,0,10"
                          TextWrapping="Wrap"
                          HorizontalAlignment="Center"/>

                <!-- Login Button -->
                <Button Content="ВОЙТИ"
                       Command="{Binding LoginCommand}"
                       Height="42"
                       FontSize="15"
                       FontWeight="Bold"
                       Cursor="Hand"
                       Margin="0,10,0,0"
                       IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBooleanConverter}}">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#1976D2"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border"
                                                Background="{TemplateBinding Background}"
                                                CornerRadius="4"
                                                Padding="10">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#1565C0"/>
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter TargetName="border" Property="Background" Value="#90CAF9"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- Progress Bar -->
                <ProgressBar IsIndeterminate="True"
                            Height="4"
                            Margin="0,15,0,0"
                            Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
