<Page x:Class="VendingMachineDesktop.Views.Pages.AdditionalPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      xmlns:converters="clr-namespace:VendingMachineDesktop.Utilities.Converters"
      Background="#F5F5F5">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Page.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <materialDesign:Card Grid.Row="0" Padding="20" Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Дополнительные" FontSize="24" FontWeight="SemiBold" Foreground="#212121"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Command="{Binding ExportCsvCommand}"
                            Style="{StaticResource MaterialDesignOutlinedButton}" Height="36">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="FileExport" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="Экспорт"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </materialDesign:Card>

        <!-- Tabs -->
        <TabControl Grid.Row="1"
                    SelectedIndex="{Binding SelectedTabIndex}"
                    Style="{StaticResource MaterialDesignNavigationRailTabControl}">

            <!-- News Tab -->
            <TabItem Header="Новости">
                <Grid Margin="0,15,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
                        <Button Command="{Binding AddNewsCommand}" Style="{StaticResource MaterialDesignRaisedButton}" Height="36">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Plus" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="Добавить новость"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <materialDesign:Card Grid.Row="1">
                        <Grid>
                            <DataGrid ItemsSource="{Binding News}"
                                      SelectedItem="{Binding SelectedNews}"
                                      AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                                      SelectionMode="Single" IsReadOnly="True" RowHeight="48"
                                      HeadersVisibility="All" GridLinesVisibility="Horizontal" AlternationCount="2">
                                <DataGrid.RowStyle>
                                    <Style TargetType="DataGridRow">
                                        <Setter Property="Background" Value="White"/>
                                        <Style.Triggers>
                                            <Trigger Property="AlternationIndex" Value="1"><Setter Property="Background" Value="#FAFAFA"/></Trigger>
                                            <Trigger Property="IsSelected" Value="True"><Setter Property="Background" Value="#E3F2FD"/></Trigger>
                                            <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#F5F5F5"/></Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.RowStyle>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Заголовок" Binding="{Binding Title}" Width="*" MinWidth="250" FontSize="13" FontWeight="SemiBold"/>
                                    <DataGridTextColumn Header="Автор" Binding="{Binding AuthorName}" Width="180" FontSize="13"/>
                                    <DataGridTextColumn Header="Дата" Binding="{Binding PublishedAt, StringFormat={}{0:dd.MM.yyyy HH:mm}}" Width="150" FontSize="13"/>
                                    <DataGridTemplateColumn Header="Активна" Width="80">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <materialDesign:PackIcon Width="20" Height="20" HorizontalAlignment="Center">
                                                    <materialDesign:PackIcon.Style>
                                                        <Style TargetType="materialDesign:PackIcon">
                                                            <Setter Property="Kind" Value="CloseCircle"/>
                                                            <Setter Property="Foreground" Value="#F44336"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                                    <Setter Property="Kind" Value="CheckCircle"/>
                                                                    <Setter Property="Foreground" Value="#4CAF50"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </materialDesign:PackIcon.Style>
                                                </materialDesign:PackIcon>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="Действия" Width="100">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                    <Button Command="{Binding DataContext.EditNewsCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                            CommandParameter="{Binding}"
                                                            Style="{StaticResource MaterialDesignIconButton}" ToolTip="Редактировать"
                                                            Width="32" Height="32" Margin="4,0">
                                                        <materialDesign:PackIcon Kind="Pencil" Width="18" Height="18" Foreground="#2196F3"/>
                                                    </Button>
                                                    <Button Command="{Binding DataContext.DeleteNewsCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                            CommandParameter="{Binding}"
                                                            Style="{StaticResource MaterialDesignIconButton}" ToolTip="Удалить"
                                                            Width="32" Height="32" Margin="4,0">
                                                        <materialDesign:PackIcon Kind="Delete" Width="18" Height="18" Foreground="#F44336"/>
                                                    </Button>
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>

                            <TextBlock Text="Новости отсутствуют"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       FontSize="14" Foreground="#757575"
                                       Visibility="{Binding HasNoNews, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        </Grid>
                    </materialDesign:Card>
                </Grid>
            </TabItem>

            <!-- Contracts Tab -->
            <TabItem Header="Контракты">
                <Grid Margin="0,15,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
                        <Button Command="{Binding AddContractCommand}" Style="{StaticResource MaterialDesignRaisedButton}" Height="36">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Plus" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="Добавить контракт"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <materialDesign:Card Grid.Row="1">
                        <Grid>
                            <DataGrid ItemsSource="{Binding Contracts}"
                                      SelectedItem="{Binding SelectedContract}"
                                      AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                                      SelectionMode="Single" IsReadOnly="True" RowHeight="48"
                                      HeadersVisibility="All" GridLinesVisibility="Horizontal" AlternationCount="2">
                                <DataGrid.RowStyle>
                                    <Style TargetType="DataGridRow">
                                        <Setter Property="Background" Value="White"/>
                                        <Style.Triggers>
                                            <Trigger Property="AlternationIndex" Value="1"><Setter Property="Background" Value="#FAFAFA"/></Trigger>
                                            <Trigger Property="IsSelected" Value="True"><Setter Property="Background" Value="#E3F2FD"/></Trigger>
                                            <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#F5F5F5"/></Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.RowStyle>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Номер" Binding="{Binding ContractNumber}" Width="160" FontSize="13" FontWeight="SemiBold"/>
                                    <DataGridTextColumn Header="Компания" Binding="{Binding CompanyName, TargetNullValue='-'}" Width="180" FontSize="13"/>
                                    <DataGridTextColumn Header="Автомат" Binding="{Binding VendingMachineName}" Width="180" FontSize="13"/>
                                    <DataGridTextColumn Header="Начало" Binding="{Binding StartDate, StringFormat={}{0:dd.MM.yyyy}}" Width="110" FontSize="13"/>
                                    <DataGridTextColumn Header="Окончание" Binding="{Binding EndDate, StringFormat={}{0:dd.MM.yyyy}}" Width="110" FontSize="13"/>
                                    <DataGridTextColumn Header="Аренда/мес" Binding="{Binding MonthlyRent, StringFormat={}{0:N2} ₽}" Width="120" FontSize="13"/>
                                    <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="100" FontSize="13"/>
                                    <DataGridTemplateColumn Header="Действия" Width="140">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                    <Button Command="{Binding DataContext.EditContractCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                            CommandParameter="{Binding}"
                                                            Style="{StaticResource MaterialDesignIconButton}" ToolTip="Редактировать"
                                                            Width="32" Height="32" Margin="2,0">
                                                        <materialDesign:PackIcon Kind="Pencil" Width="18" Height="18" Foreground="#2196F3"/>
                                                    </Button>
                                                    <Button Command="{Binding DataContext.SignContractCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                            CommandParameter="{Binding}"
                                                            Style="{StaticResource MaterialDesignIconButton}" ToolTip="Подписать"
                                                            Width="32" Height="32" Margin="2,0">
                                                        <materialDesign:PackIcon Kind="Draw" Width="18" Height="18" Foreground="#4CAF50"/>
                                                    </Button>
                                                    <Button Command="{Binding DataContext.DeleteContractCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                            CommandParameter="{Binding}"
                                                            Style="{StaticResource MaterialDesignIconButton}" ToolTip="Удалить"
                                                            Width="32" Height="32" Margin="2,0">
                                                        <materialDesign:PackIcon Kind="Delete" Width="18" Height="18" Foreground="#F44336"/>
                                                    </Button>
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>

                            <TextBlock Text="Контракты отсутствуют"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       FontSize="14" Foreground="#757575"
                                       Visibility="{Binding HasNoContracts, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        </Grid>
                    </materialDesign:Card>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Page>
