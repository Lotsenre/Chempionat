<Page x:Class="VendingMachineDesktop.Views.Pages.CompaniesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      xmlns:converters="clr-namespace:VendingMachineDesktop.Utilities.Converters"
      xmlns:services="clr-namespace:VendingMachineDesktop.Services"
      Background="#F5F5F5">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Page.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header with Title and Actions -->
        <materialDesign:Card Grid.Row="0" Padding="20" Margin="0,0,0,20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Title -->
                <TextBlock Grid.Row="0"
                           Text="Список компаний"
                           FontSize="24"
                           FontWeight="SemiBold"
                           Foreground="#212121"
                           Margin="0,0,0,6"/>

                <TextBlock Grid.Row="0"
                           Text="{Binding TotalCountText}"
                           FontSize="12"
                           Foreground="#757575"
                           VerticalAlignment="Bottom"
                           Margin="0,28,0,20"/>

                <!-- Toolbar -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left: Row Count Selector and Filter -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Показать"
                                   VerticalAlignment="Center"
                                   Foreground="#757575"
                                   Margin="0,0,10,0"/>
                        <ComboBox SelectedValue="{Binding PageSize}"
                                  SelectedValuePath="Tag"
                                  Width="80"
                                  Style="{StaticResource WhiteOutlinedComboBox}">
                            <ComboBoxItem Content="10" Tag="10"/>
                            <ComboBoxItem Content="25" Tag="25"/>
                            <ComboBoxItem Content="50" Tag="50" IsSelected="True"/>
                            <ComboBoxItem Content="100" Tag="100"/>
                        </ComboBox>
                        <TextBlock Text="записей"
                                   VerticalAlignment="Center"
                                   Foreground="#757575"
                                   Margin="10,0,30,0"/>

                        <!-- Search Filter -->
                        <TextBox materialDesign:HintAssist.Hint="Фильтр"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Width="300"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                    </StackPanel>

                    <!-- Right: Action Buttons and View Toggle -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                        <!-- Add Button (Admin) -->
                        <Button Command="{Binding AddCommand}"
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                Margin="0,0,10,0"
                                Height="36"
                                Visibility="{Binding CanEdit, Source={x:Static services:RoleHelper.Instance}, Converter={StaticResource BoolToVisibilityConverter}}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Plus" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="Добавить"/>
                            </StackPanel>
                        </Button>

                        <!-- Export CSV Button -->
                        <Button Command="{Binding ExportCsvCommand}"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Margin="0,0,15,0"
                                Height="36">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="FileExport" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="Экспорт"/>
                            </StackPanel>
                        </Button>

                        <!-- View Mode Toggle Icons -->
                        <ToggleButton IsChecked="{Binding IsTileView}"
                                      Style="{StaticResource MaterialDesignFlatPrimaryToggleButton}"
                                      ToolTip="Плитка"
                                      Width="36"
                                      Height="36"
                                      Margin="0,0,5,0">
                            <materialDesign:PackIcon Kind="ViewModule" Width="20" Height="20"/>
                        </ToggleButton>
                        <ToggleButton IsChecked="{Binding IsTableView}"
                                      Style="{StaticResource MaterialDesignFlatPrimaryToggleButton}"
                                      ToolTip="Таблица"
                                      Width="36"
                                      Height="36">
                            <materialDesign:PackIcon Kind="Table" Width="20" Height="20"/>
                        </ToggleButton>
                    </StackPanel>
                </Grid>
            </Grid>
        </materialDesign:Card>

        <!-- DataGrid -->
        <materialDesign:Card Grid.Row="1" Margin="0,0,0,20">
            <Grid>
                <DataGrid ItemsSource="{Binding Companies}"
                      SelectedItem="{Binding SelectedCompany}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      SelectionMode="Single"
                      IsReadOnly="True"
                      RowHeight="48"
                      HeadersVisibility="All"
                      GridLinesVisibility="Horizontal"
                      AlternationCount="2">

                <!-- Alternating Row Colors -->
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Background" Value="White"/>
                        <Style.Triggers>
                            <Trigger Property="AlternationIndex" Value="1">
                                <Setter Property="Background" Value="#FAFAFA"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#E3F2FD"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F5F5F5"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>

                <DataGrid.Columns>
                    <!-- Name -->
                    <DataGridTextColumn Header="Название"
                                        Binding="{Binding Name}"
                                        Width="*"
                                        MinWidth="200"
                                        FontSize="13"
                                        FontWeight="SemiBold"/>

                    <!-- Parent Company -->
                    <DataGridTextColumn Header="Вышестоящая"
                                        Binding="{Binding ParentCompanyName, TargetNullValue='-'}"
                                        Width="180"
                                        FontSize="13"/>

                    <!-- Address -->
                    <DataGridTextColumn Header="Адрес"
                                        Binding="{Binding Address}"
                                        Width="*"
                                        MinWidth="250"
                                        FontSize="13"/>

                    <!-- Contacts -->
                    <DataGridTextColumn Header="Контакты"
                                        Binding="{Binding ContactInfo}"
                                        Width="200"
                                        FontSize="13"/>

                    <!-- Operating Since -->
                    <DataGridTextColumn Header="В работе с"
                                        Binding="{Binding WorkingSince, StringFormat={}{0:dd.MM.yyyy}}"
                                        Width="120"
                                        FontSize="13"/>

                    <!-- Actions Column -->
                    <DataGridTemplateColumn Header="Действия" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <!-- Edit Button (Admin) -->
                                    <Button Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource MaterialDesignIconButton}"
                                            ToolTip="Редактировать"
                                            Width="32"
                                            Height="32"
                                            Margin="4,0"
                                            Visibility="{Binding CanEdit, Source={x:Static services:RoleHelper.Instance}, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <materialDesign:PackIcon Kind="Pencil" Width="18" Height="18" Foreground="#2196F3"/>
                                    </Button>

                                    <!-- Delete Button (только Admin) -->
                                    <Button Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource MaterialDesignIconButton}"
                                            ToolTip="Удалить"
                                            Width="32"
                                            Height="32"
                                            Margin="4,0"
                                            Visibility="{Binding CanDelete, Source={x:Static services:RoleHelper.Instance}, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <materialDesign:PackIcon Kind="Delete" Width="18" Height="18" Foreground="#F44336"/>
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

                <!-- Empty State Message -->
                <TextBlock Text="В таблице отсутствуют данные"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontSize="14"
                           Foreground="#757575"
                           Visibility="{Binding HasNoData, Converter={StaticResource BoolToVisibilityConverter}}"/>
            </Grid>
        </materialDesign:Card>

        <!-- Pagination -->
        <materialDesign:Card Grid.Row="2" Padding="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Records Count Info -->
                <TextBlock Grid.Column="0"
                           VerticalAlignment="Center"
                           Foreground="#757575"
                           FontSize="13">
                    <Run Text="Записи с"/>
                    <Run Text="{Binding StartRecord, Mode=OneWay, FallbackValue=0}" FontWeight="SemiBold"/>
                    <Run Text="до"/>
                    <Run Text="{Binding EndRecord, Mode=OneWay, FallbackValue=0}" FontWeight="SemiBold"/>
                    <Run Text="из"/>
                    <Run Text="{Binding TotalRecords, Mode=OneWay, FallbackValue=0}" FontWeight="SemiBold"/>
                    <Run Text="записей"/>
                </TextBlock>

                <!-- Page navigation -->
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Content="&lt;"
                            Command="{Binding PreviousPageCommand}"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            Width="40"
                            Height="36"
                            Margin="0,0,5,0"/>

                    <ItemsControl ItemsSource="{Binding PageNumbers}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Content="{Binding}"
                                        Command="{Binding DataContext.GoToPageCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource MaterialDesignOutlinedButton}"
                                        Width="40"
                                        Height="36"
                                        Margin="0,0,5,0"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Button Content="&gt;"
                            Command="{Binding NextPageCommand}"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            Width="40"
                            Height="36"/>
                </StackPanel>
            </Grid>
        </materialDesign:Card>
    </Grid>
</Page>
