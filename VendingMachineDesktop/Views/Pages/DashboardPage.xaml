<Page x:Class="VendingMachineDesktop.Views.Pages.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
      Background="#F5F5F5">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Page Title -->
            <TextBlock Grid.Row="0"
                       Text="Личный кабинет. Главная"
                       FontSize="24"
                       FontWeight="SemiBold"
                       Foreground="#212121"
                       Margin="0,0,0,20"/>

            <!-- Row 1: Three blocks in one row (Efficiency, Status, Summary) -->
            <Grid Grid.Row="1" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="15"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="15"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Block 1: Network Efficiency with Circular Progress -->
                <materialDesign:Card Grid.Column="0" Padding="20">
                    <StackPanel>
                        <TextBlock Text="Эффективность сети"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="#212121"
                                   Margin="0,0,0,15"/>

                        <Grid Height="180">
                            <!-- Circular Progress Bar using LiveCharts Gauge -->
                            <lvc:PieChart Series="{Binding EfficiencyGaugeSeries}"
                                         InitialRotation="-90"
                                         MaxAngle="360"
                                         MinValue="0"
                                         MaxValue="100"
                                         Height="160"
                                         Width="160"/>

                            <!-- Center Text -->
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="Под управлением"
                                           FontSize="10"
                                           HorizontalAlignment="Center"
                                           Foreground="#9E9E9E"/>
                                <TextBlock Text="{Binding TotalMachines, FallbackValue=9}"
                                           FontSize="28"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           Foreground="#1976D2"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock HorizontalAlignment="Center"
                                   Margin="0,10,0,0"
                                   FontSize="12"
                                   Foreground="#757575">
                            <Run Text="Работающих автоматов:"/>
                            <Run Text="{Binding NetworkEfficiency, StringFormat={}{0:F0}%, FallbackValue=100%}" FontWeight="SemiBold" Foreground="#4CAF50"/>
                        </TextBlock>
                    </StackPanel>
                </materialDesign:Card>

                <!-- Block 2: Network Status with Pie Chart -->
                <materialDesign:Card Grid.Column="2" Padding="20">
                    <StackPanel>
                        <TextBlock Text="Состояние сети"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="#212121"
                                   Margin="0,0,0,15"/>

                        <Grid Height="180">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Pie Chart -->
                            <lvc:PieChart Grid.Column="0"
                                         Series="{Binding NetworkStatusSeries}"
                                         InitialRotation="-90"
                                         Height="140"
                                         Width="140"
                                         HorizontalAlignment="Center"/>

                            <!-- Legend -->
                            <StackPanel Grid.Column="1"
                                       VerticalAlignment="Center"
                                       Margin="10,0,0,0">
                                <StackPanel Orientation="Horizontal" Margin="0,4">
                                    <Ellipse Width="12" Height="12" Fill="#4CAF50" Margin="0,0,8,0"/>
                                    <TextBlock FontSize="12" Foreground="#424242">
                                        <Run Text="Работает:" FontWeight="SemiBold"/>
                                        <Run Text="{Binding NetworkStatus.Working, FallbackValue=0, Mode=OneWay}"/>
                                    </TextBlock>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,4">
                                    <Ellipse Width="12" Height="12" Fill="#F44336" Margin="0,0,8,0"/>
                                    <TextBlock FontSize="12" Foreground="#424242">
                                        <Run Text="Не работает:" FontWeight="SemiBold"/>
                                        <Run Text="{Binding NetworkStatus.NotWorking, FallbackValue=0, Mode=OneWay}"/>
                                    </TextBlock>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,4">
                                    <Ellipse Width="12" Height="12" Fill="#2196F3" Margin="0,0,8,0"/>
                                    <TextBlock FontSize="12" Foreground="#424242">
                                        <Run Text="На обслуживании:" FontWeight="SemiBold"/>
                                        <Run Text="{Binding NetworkStatus.OnMaintenance, FallbackValue=0, Mode=OneWay}"/>
                                    </TextBlock>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </materialDesign:Card>

                <!-- Block 3: Summary -->
                <materialDesign:Card Grid.Column="4" Padding="20">
                    <StackPanel>
                        <TextBlock Text="Сводка"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="#212121"
                                   Margin="0,0,0,15"/>

                        <StackPanel VerticalAlignment="Top">
                            <!-- Row 1 -->
                            <Grid Margin="0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Денег в ТА" FontSize="12" Foreground="#757575"/>
                                <TextBlock Grid.Column="1" FontSize="12" FontWeight="SemiBold" Foreground="#212121"
                                           Text="{Binding Summary.TotalSales, StringFormat={}{0:N0} р, FallbackValue=27889 р}"/>
                            </Grid>
                            <!-- Row 2 -->
                            <Grid Margin="0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Сдача в ТА" FontSize="12" Foreground="#757575"/>
                                <TextBlock Grid.Column="1" FontSize="12" FontWeight="SemiBold" Foreground="#212121"
                                           Text="{Binding Summary.ChangeAmount, StringFormat={}{0:N0} р, FallbackValue=12319 р}"/>
                            </Grid>
                            <!-- Row 3 -->
                            <Grid Margin="0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Выручка, вчера" FontSize="12" Foreground="#757575"/>
                                <TextBlock Grid.Column="1" FontSize="12" FontWeight="SemiBold" Foreground="#212121"
                                           Text="{Binding Summary.YesterdayRevenue, StringFormat={}{0:N0} р, FallbackValue=9860 р}"/>
                            </Grid>
                            <!-- Row 4 -->
                            <Grid Margin="0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Продаж, вчера" FontSize="12" Foreground="#757575"/>
                                <TextBlock Grid.Column="1" FontSize="12" FontWeight="SemiBold" Foreground="#212121"
                                           Text="{Binding Summary.SalesCount, StringFormat={}{0:N0} шт, FallbackValue=32403 шт}"/>
                            </Grid>
                            <!-- Row 5 -->
                            <Grid Margin="0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Инкассация, вчера" FontSize="12" Foreground="#757575"/>
                                <TextBlock Grid.Column="1" FontSize="12" FontWeight="SemiBold" Foreground="#212121"
                                           Text="{Binding Summary.TotalCollection, StringFormat={}{0:N0} р, FallbackValue=2461 р}"/>
                            </Grid>
                            <!-- Row 6 -->
                            <Grid Margin="0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Обслуживание ТА, по плану" FontSize="12" Foreground="#757575"/>
                                <TextBlock Grid.Column="1" FontSize="12" FontWeight="SemiBold" Foreground="#212121"
                                           Text="{Binding Summary.MaintenanceCount, StringFormat={}{0} / 3, FallbackValue=0 / 3}"/>
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </materialDesign:Card>
            </Grid>

            <!-- Row 2: Sales Dynamics Chart and News -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="15"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Block 4: Sales Dynamics Chart with LiveCharts -->
                <materialDesign:Card Grid.Column="0" Padding="20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Кнопки переключения -->
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
                            <Button x:Name="BtnByAmount"
                                    Content="По сумме"
                                    Click="BtnByAmount_Click"
                                    Margin="0,0,5,0"
                                    Padding="12,6"
                                    Background="#1976D2"
                                    Foreground="White"
                                    BorderThickness="0"
                                    FontWeight="SemiBold"
                                    FontSize="12"
                                    Cursor="Hand"/>
                            <Button x:Name="BtnByQuantity"
                                    Content="По количеству"
                                    Click="BtnByQuantity_Click"
                                    Padding="12,6"
                                    Background="#E3F2FD"
                                    Foreground="#1976D2"
                                    BorderThickness="0"
                                    FontWeight="SemiBold"
                                    FontSize="12"
                                    Cursor="Hand"/>
                        </StackPanel>

                        <!-- График -->
                        <lvc:CartesianChart Grid.Row="1"
                                           x:Name="SalesChart"
                                           Series="{Binding SalesSeries}"
                                           XAxes="{Binding SalesXAxes}"
                                           YAxes="{Binding SalesYAxes}"
                                           Height="300"
                                           TooltipPosition="Top"/>
                    </Grid>
                </materialDesign:Card>

                <!-- Block 5: News -->
                <materialDesign:Card Grid.Column="2" Padding="20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Заголовок Новости -->
                        <Button x:Name="BtnNews"
                                Grid.Row="0"
                                Content="Новости"
                                Click="BtnNews_Click"
                                HorizontalAlignment="Left"
                                Padding="12,6"
                                Margin="0,0,0,15"
                                Background="#E3F2FD"
                                Foreground="#1976D2"
                                BorderThickness="0"
                                FontWeight="SemiBold"
                                FontSize="12"
                                Cursor="Hand"/>

                        <!-- Список новостей (скрыт по умолчанию) -->
                        <ScrollViewer x:Name="NewsListContainer"
                                      Grid.Row="1"
                                      VerticalScrollBarVisibility="Auto"
                                      Visibility="Collapsed">
                            <ItemsControl ItemsSource="{Binding NewsList}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="#E0E0E0"
                                                BorderThickness="0,0,0,1"
                                                Padding="0,8,0,10"
                                                Margin="0,0,0,8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding Date, StringFormat={}{0:dd.MM.yy}}"
                                                           FontSize="11"
                                                           Foreground="#9E9E9E"
                                                           VerticalAlignment="Top"
                                                           Margin="0,0,12,0"
                                                           Width="50"/>
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="{Binding Title}"
                                                               FontWeight="SemiBold"
                                                               FontSize="13"
                                                               TextWrapping="Wrap"
                                                               Foreground="#212121"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </materialDesign:Card>
            </Grid>
        </Grid>
    </ScrollViewer>
</Page>
