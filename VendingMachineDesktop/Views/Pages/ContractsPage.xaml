<Page x:Class="VendingMachineDesktop.Views.Pages.ContractsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      xmlns:converters="clr-namespace:VendingMachineDesktop.Utilities.Converters"
      xmlns:services="clr-namespace:VendingMachineDesktop.Services"
      Background="#F5F5F5">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Page.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <materialDesign:Card Grid.Row="0" Padding="20" Margin="0,0,0,20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Контракты" FontSize="24" FontWeight="SemiBold" Foreground="#212121" Margin="0,0,0,6"/>
                <TextBlock Grid.Row="0" Text="{Binding TotalCountText}" FontSize="12" Foreground="#757575" VerticalAlignment="Bottom" Margin="0,28,0,20"/>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Показать" VerticalAlignment="Center" Foreground="#757575" Margin="0,0,10,0"/>
                        <ComboBox SelectedValue="{Binding PageSize}" SelectedValuePath="Tag" Width="80"
                                  Style="{StaticResource WhiteOutlinedComboBox}">
                            <ComboBoxItem Content="10" Tag="10"/>
                            <ComboBoxItem Content="25" Tag="25"/>
                            <ComboBoxItem Content="50" Tag="50" IsSelected="True"/>
                            <ComboBoxItem Content="100" Tag="100"/>
                        </ComboBox>
                        <TextBlock Text="записей" VerticalAlignment="Center" Foreground="#757575" Margin="10,0,30,0"/>
                        <TextBox materialDesign:HintAssist.Hint="Фильтр"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Width="300" Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Command="{Binding AddCommand}" Style="{StaticResource MaterialDesignRaisedButton}" Margin="0,0,10,0" Height="36"
                                Visibility="{Binding CanEdit, Source={x:Static services:RoleHelper.Instance}, Converter={StaticResource BoolToVisibilityConverter}}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Plus" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="Добавить"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding ExportCsvCommand}" Style="{StaticResource MaterialDesignOutlinedButton}" Height="36">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="FileExport" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="Экспорт"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Grid>
        </materialDesign:Card>

        <!-- DataGrid -->
        <materialDesign:Card Grid.Row="1" Margin="0,0,0,20">
            <Grid>
                <DataGrid ItemsSource="{Binding Contracts}"
                          SelectedItem="{Binding SelectedContract}"
                          AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                          SelectionMode="Single" IsReadOnly="True" RowHeight="48"
                          HeadersVisibility="All" GridLinesVisibility="Horizontal" AlternationCount="2">

                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="White"/>
                            <Style.Triggers>
                                <Trigger Property="AlternationIndex" Value="1"><Setter Property="Background" Value="#FAFAFA"/></Trigger>
                                <Trigger Property="IsSelected" Value="True"><Setter Property="Background" Value="#E3F2FD"/></Trigger>
                                <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#F5F5F5"/></Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Номер" Binding="{Binding ContractNumber}" Width="160" FontSize="13" FontWeight="SemiBold"/>
                        <DataGridTextColumn Header="Компания" Binding="{Binding CompanyName, TargetNullValue='-'}" Width="180" FontSize="13"/>
                        <DataGridTextColumn Header="Автомат" Binding="{Binding VendingMachineName}" Width="180" FontSize="13"/>
                        <DataGridTextColumn Header="Начало" Binding="{Binding StartDate, StringFormat={}{0:dd.MM.yyyy}}" Width="110" FontSize="13"/>
                        <DataGridTextColumn Header="Окончание" Binding="{Binding EndDate, StringFormat={}{0:dd.MM.yyyy}}" Width="110" FontSize="13"/>
                        <DataGridTextColumn Header="Аренда/мес" Binding="{Binding MonthlyRent, StringFormat={}{0:N0} ₽}" Width="120" FontSize="13"/>
                        <DataGridTextColumn Header="Аренда/год" Binding="{Binding YearlyRent, StringFormat={}{0:N0} ₽}" Width="120" FontSize="13"/>
                        <DataGridTemplateColumn Header="Статус" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Status}" FontSize="13">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#757575"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="Signed">
                                                        <Setter Property="Foreground" Value="#4CAF50"/>
                                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Active">
                                                        <Setter Property="Foreground" Value="#2196F3"/>
                                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Expired">
                                                        <Setter Property="Foreground" Value="#F44336"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Действия" Width="140">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <Button Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource MaterialDesignIconButton}" ToolTip="Редактировать"
                                                Width="32" Height="32" Margin="2,0"
                                                Visibility="{Binding CanEdit, Source={x:Static services:RoleHelper.Instance}, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <materialDesign:PackIcon Kind="Pencil" Width="18" Height="18" Foreground="#2196F3"/>
                                        </Button>
                                        <Button Command="{Binding DataContext.SignCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource MaterialDesignIconButton}" ToolTip="Подписать"
                                                Width="32" Height="32" Margin="2,0"
                                                Visibility="{Binding CanEdit, Source={x:Static services:RoleHelper.Instance}, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <materialDesign:PackIcon Kind="Draw" Width="18" Height="18" Foreground="#4CAF50"/>
                                        </Button>
                                        <Button Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource MaterialDesignIconButton}" ToolTip="Удалить"
                                                Width="32" Height="32" Margin="2,0"
                                                Visibility="{Binding CanDelete, Source={x:Static services:RoleHelper.Instance}, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <materialDesign:PackIcon Kind="Delete" Width="18" Height="18" Foreground="#F44336"/>
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <TextBlock Text="В таблице отсутствуют данные"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           FontSize="14" Foreground="#757575"
                           Visibility="{Binding HasNoData, Converter={StaticResource BoolToVisibilityConverter}}"/>
            </Grid>
        </materialDesign:Card>

        <!-- Pagination -->
        <materialDesign:Card Grid.Row="2" Padding="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" VerticalAlignment="Center" Foreground="#757575" FontSize="13">
                    <Run Text="Записи с"/>
                    <Run Text="{Binding StartRecord, Mode=OneWay, FallbackValue=0}" FontWeight="SemiBold"/>
                    <Run Text="до"/>
                    <Run Text="{Binding EndRecord, Mode=OneWay, FallbackValue=0}" FontWeight="SemiBold"/>
                    <Run Text="из"/>
                    <Run Text="{Binding TotalRecords, Mode=OneWay, FallbackValue=0}" FontWeight="SemiBold"/>
                    <Run Text="записей"/>
                </TextBlock>

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Content="&lt;" Command="{Binding PreviousPageCommand}"
                            Style="{StaticResource MaterialDesignOutlinedButton}" Width="40" Height="36" Margin="0,0,5,0"/>
                    <ItemsControl ItemsSource="{Binding PageNumbers}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Content="{Binding}"
                                        Command="{Binding DataContext.GoToPageCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource MaterialDesignOutlinedButton}" Width="40" Height="36" Margin="0,0,5,0"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <Button Content="&gt;" Command="{Binding NextPageCommand}"
                            Style="{StaticResource MaterialDesignOutlinedButton}" Width="40" Height="36"/>
                </StackPanel>
            </Grid>
        </materialDesign:Card>
    </Grid>
</Page>
