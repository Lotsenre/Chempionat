<Page x:Class="VendingMachineDesktop.Views.Pages.MonitorPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      xmlns:converters="clr-namespace:VendingMachineDesktop.Utilities.Converters"
      Background="White">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:ColorToBrushConverter x:Key="ColorToBrushConverter"/>
        <converters:BoolToBackgroundConverter x:Key="BoolToBackgroundConverter"/>

        <!-- Стиль для ComboBox -->
        <Style x:Key="WhiteComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <!-- Стиль кнопки-фильтра (круглая иконка) -->
        <Style x:Key="FilterIconButtonStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#1976D2"/>
                                <Setter TargetName="border" Property="Background" Value="#E3F2FD"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#F5F5F5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль для текстовой кнопки-фильтра -->
        <Style x:Key="FilterTextButtonStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#1976D2"/>
                                <Setter TargetName="border" Property="Background" Value="#E3F2FD"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#F5F5F5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль кнопки Применить -->
        <Style x:Key="ApplyButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#17A2B8"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль кнопки Очистить -->
        <Style x:Key="ClearButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#E0E0E0"/>
            <Setter Property="Foreground" Value="#333"/>
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль для прогресс-бара загрузки -->
        <Style x:Key="LoadProgressBarStyle" TargetType="ProgressBar">
            <Setter Property="Height" Value="8"/>
            <Setter Property="Margin" Value="0,1"/>
            <Setter Property="Background" Value="#E0E0E0"/>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#4A90A4" Padding="15,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Монитор торговых автоматов"
                               Foreground="White"
                               FontSize="18"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding LastUpdateTime}"
                               Foreground="#B0E0E6"
                               FontSize="11"
                               Margin="0,2,0,0"/>
                </StackPanel>
                <!-- Иконки справа -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="8" ToolTip="Таблица">
                        <TextBlock Text="&#xE8F1;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="White"/>
                    </Button>
                    <Button Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="8" ToolTip="Список">
                        <TextBlock Text="&#xE8FD;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="White"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Filter Row -->
        <Border Grid.Row="1" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="15,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Общее состояние -->
                <StackPanel Grid.Column="0" Margin="0,0,25,0">
                    <TextBlock Text="Общее состояние" FontSize="11" Foreground="#666" Margin="0,0,0,6"/>
                    <StackPanel Orientation="Horizontal">
                        <ToggleButton Style="{StaticResource FilterIconButtonStyle}"
                                      IsChecked="{Binding FilterStatusGreen}"
                                      Margin="0,0,4,0" ToolTip="Работает">
                            <Ellipse Width="20" Height="20" Fill="#4CAF50"/>
                        </ToggleButton>
                        <ToggleButton Style="{StaticResource FilterIconButtonStyle}"
                                      IsChecked="{Binding FilterStatusRed}"
                                      Margin="0,0,4,0" ToolTip="Не работает">
                            <Ellipse Width="20" Height="20" Fill="#F44336"/>
                        </ToggleButton>
                        <ToggleButton Style="{StaticResource FilterIconButtonStyle}"
                                      IsChecked="{Binding FilterStatusBlue}"
                                      ToolTip="На обслуживании">
                            <Ellipse Width="20" Height="20" Fill="#2196F3"/>
                        </ToggleButton>
                    </StackPanel>
                </StackPanel>

                <!-- Подключение -->
                <StackPanel Grid.Column="1" Margin="0,0,25,0">
                    <TextBlock Text="Подключение" FontSize="11" Foreground="#666" Margin="0,0,0,6"/>
                    <StackPanel Orientation="Horizontal">
                        <ToggleButton Style="{StaticResource FilterTextButtonStyle}"
                                      IsChecked="{Binding FilterConnectionMdb}"
                                      Margin="0,0,4,0" ToolTip="MDB">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE774;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            </StackPanel>
                        </ToggleButton>
                        <ToggleButton Style="{StaticResource FilterTextButtonStyle}"
                                      IsChecked="{Binding FilterConnectionMdb}"
                                      Margin="0,0,4,0" ToolTip="MDB">
                            <TextBlock Text="MDB" FontWeight="SemiBold"/>
                        </ToggleButton>
                        <ToggleButton Style="{StaticResource FilterTextButtonStyle}"
                                      IsChecked="{Binding FilterConnectionExePh}"
                                      Margin="0,0,4,0" ToolTip="EXE PH">
                            <TextBlock Text="EXE&#x000A;PH" TextAlignment="Center" FontWeight="SemiBold" FontSize="9"/>
                        </ToggleButton>
                        <ToggleButton Style="{StaticResource FilterTextButtonStyle}"
                                      IsChecked="{Binding FilterConnectionExeSt}"
                                      ToolTip="EXE ST">
                            <TextBlock Text="EXE&#x000A;ST" TextAlignment="Center" FontWeight="SemiBold" FontSize="9"/>
                        </ToggleButton>
                    </StackPanel>
                </StackPanel>

                <!-- Дополнительные статусы -->
                <StackPanel Grid.Column="2" Margin="0,0,25,0">
                    <TextBlock Text="Дополнительные статусы" FontSize="11" Foreground="#666" Margin="0,0,0,6"/>
                    <StackPanel Orientation="Horizontal">
                        <!-- Мало товара красный -->
                        <ToggleButton Style="{StaticResource FilterIconButtonStyle}"
                                      IsChecked="{Binding FilterFewGoods}"
                                      Margin="0,0,2,0" ToolTip="Мало товара (критично)">
                            <Image Source="/Assets/Icons/Statuses/FewGoods.png" Width="22" Height="22"/>
                        </ToggleButton>
                        <!-- Мало товара желтый -->
                        <ToggleButton Style="{StaticResource FilterIconButtonStyle}"
                                      IsChecked="{Binding FilterFewGoodsYellow}"
                                      Margin="0,0,2,0" ToolTip="Мало товара (предупреждение)">
                            <Image Source="/Assets/Icons/Statuses/FewGoods.png" Width="22" Height="22" Opacity="0.6"/>
                        </ToggleButton>
                        <!-- Мало сдачи красный -->
                        <ToggleButton Style="{StaticResource FilterIconButtonStyle}"
                                      IsChecked="{Binding FilterFewChange}"
                                      Margin="0,0,2,0" ToolTip="Мало сдачи (критично)">
                            <Image Source="/Assets/Icons/Statuses/FewChange.png" Width="22" Height="22"/>
                        </ToggleButton>
                        <!-- Мало сдачи желтый -->
                        <ToggleButton Style="{StaticResource FilterIconButtonStyle}"
                                      IsChecked="{Binding FilterFewChangeYellow}"
                                      Margin="0,0,2,0" ToolTip="Мало сдачи (предупреждение)">
                            <Image Source="/Assets/Icons/Statuses/FewChange.png" Width="22" Height="22" Opacity="0.6"/>
                        </ToggleButton>
                        <!-- Инкассация красный -->
                        <ToggleButton Style="{StaticResource FilterIconButtonStyle}"
                                      IsChecked="{Binding FilterNoEncashment}"
                                      Margin="0,0,2,0" ToolTip="Нужна инкассация (критично)">
                            <Image Source="/Assets/Icons/Statuses/NoEncashment.png" Width="22" Height="22"/>
                        </ToggleButton>
                        <!-- Инкассация желтый -->
                        <ToggleButton Style="{StaticResource FilterIconButtonStyle}"
                                      IsChecked="{Binding FilterNoEncashmentYellow}"
                                      Margin="0,0,2,0" ToolTip="Нужна инкассация (предупреждение)">
                            <Image Source="/Assets/Icons/Statuses/NoEncashment.png" Width="22" Height="22" Opacity="0.6"/>
                        </ToggleButton>
                        <!-- Обслуживание красный -->
                        <ToggleButton Style="{StaticResource FilterIconButtonStyle}"
                                      IsChecked="{Binding FilterNoService}"
                                      Margin="0,0,2,0" ToolTip="Нужно обслуживание (критично)">
                            <Image Source="/Assets/Icons/Statuses/NoService.png" Width="22" Height="22"/>
                        </ToggleButton>
                        <!-- Обслуживание желтый -->
                        <ToggleButton Style="{StaticResource FilterIconButtonStyle}"
                                      IsChecked="{Binding FilterNoServiceYellow}"
                                      Margin="0,0,2,0" ToolTip="Нужно обслуживание (предупреждение)">
                            <Image Source="/Assets/Icons/Statuses/NoService.png" Width="22" Height="22" Opacity="0.6"/>
                        </ToggleButton>
                        <!-- Загрузка красный -->
                        <ToggleButton Style="{StaticResource FilterIconButtonStyle}"
                                      IsChecked="{Binding FilterNoFillup}"
                                      Margin="0,0,2,0" ToolTip="Нужна загрузка (критично)">
                            <Image Source="/Assets/Icons/Statuses/NoFillup.png" Width="22" Height="22"/>
                        </ToggleButton>
                        <!-- Загрузка желтый -->
                        <ToggleButton Style="{StaticResource FilterIconButtonStyle}"
                                      IsChecked="{Binding FilterNoFillupYellow}"
                                      Margin="0,0,2,0" ToolTip="Нужна загрузка (предупреждение)">
                            <Image Source="/Assets/Icons/Statuses/NoFillup.png" Width="22" Height="22" Opacity="0.6"/>
                        </ToggleButton>
                        <!-- Проблемы с оборудованием -->
                        <ToggleButton Style="{StaticResource FilterIconButtonStyle}"
                                      IsChecked="{Binding FilterHardwareProblems}"
                                      ToolTip="Проблемы с оборудованием">
                            <Image Source="/Assets/Icons/Statuses/HardwareProblems.png" Width="22" Height="22"/>
                        </ToggleButton>
                    </StackPanel>
                </StackPanel>

                <!-- Сортировка -->
                <StackPanel Grid.Column="4">
                    <TextBlock Text="Сортировка" FontSize="11" Foreground="#666" Margin="0,0,0,6"/>
                    <ComboBox Width="200"
                              Style="{StaticResource WhiteComboBoxStyle}"
                              ItemsSource="{Binding SortOptions}"
                              SelectedItem="{Binding SelectedSortOption}"
                              DisplayMemberPath="Name"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Buttons and Company Row -->
        <Border Grid.Row="2" Background="#F8F9FA" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="15,10">
            <StackPanel Orientation="Horizontal">
                <Button Content="Применить"
                        Command="{Binding ApplyFilterCommand}"
                        Style="{StaticResource ApplyButtonStyle}"
                        Margin="0,0,10,0"/>
                <Button Content="Очистить"
                        Command="{Binding ClearFilterCommand}"
                        Style="{StaticResource ClearButtonStyle}"/>
            </StackPanel>
        </Border>

        <!-- Company Selector -->
        <Border Grid.Row="3" Background="#F8F9FA" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="15,10">
            <ComboBox Width="350"
                      HorizontalAlignment="Left"
                      Style="{StaticResource WhiteComboBoxStyle}"
                      ItemsSource="{Binding Companies}"
                      SelectedItem="{Binding SelectedCompany}">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock>
                            <Run Text="{Binding Code, Mode=OneWay}"/>
                            <Run Text=" - '"/>
                            <Run Text="{Binding Name, Mode=OneWay}"/>
                            <Run Text="'"/>
                        </TextBlock>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
        </Border>

        <!-- No Results Message -->
        <Border Grid.Row="4"
                Background="#FFF3CD"
                Padding="20"
                Visibility="{Binding ShowNoResultsMessage, Converter={StaticResource BoolToVisibilityConverter}}">
            <TextBlock Text="Нет активных торговых автоматов, соответствующих заданному фильтру."
                       FontSize="14"
                       Foreground="#856404"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
        </Border>

        <!-- Data Table -->
        <DataGrid Grid.Row="4"
                  ItemsSource="{Binding MonitorData}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  GridLinesVisibility="All"
                  HorizontalGridLinesBrush="#E0E0E0"
                  VerticalGridLinesBrush="#E0E0E0"
                  RowHeight="90"
                  HeadersVisibility="Column"
                  Background="White"
                  BorderThickness="0"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Auto"
                  Visibility="{Binding ShowNoResultsMessage, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=inverse}">

            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#F5F5F5"/>
                    <Setter Property="Foreground" Value="#333"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="FontSize" Value="12"/>
                    <Setter Property="Padding" Value="8,10"/>
                    <Setter Property="BorderBrush" Value="#E0E0E0"/>
                    <Setter Property="BorderThickness" Value="0,0,1,1"/>
                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>

            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Setter Property="Background" Value="White"/>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#F8F9FA"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#E3F2FD"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>

            <DataGrid.CellStyle>
                <Style TargetType="DataGridCell">
                    <Setter Property="BorderBrush" Value="#E0E0E0"/>
                    <Setter Property="BorderThickness" Value="0,0,1,0"/>
                    <Setter Property="VerticalAlignment" Value="Center"/>
                    <Setter Property="Padding" Value="4"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="Black"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.CellStyle>

            <DataGrid.Columns>
                <!-- Чекбокс выбора -->
                <DataGridTemplateColumn Width="35">
                    <DataGridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding DataContext.SelectAll, RelativeSource={RelativeSource AncestorType=Page}}"
                                      HorizontalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.HeaderTemplate>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- № (Номер) -->
                <DataGridTemplateColumn Header="№" Width="70">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                                <Image Source="{Binding StatusDot}" Width="12" Height="12" Margin="0,0,4,0"/>
                                <TextBlock Text="{Binding Code}" FontSize="11" FontWeight="SemiBold"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- ТП (Торговый пункт) -->
                <DataGridTemplateColumn Header="ТП" Width="180">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Margin="6,4" VerticalAlignment="Center">
                                <TextBlock FontWeight="SemiBold" FontSize="12" Foreground="#1976D2" TextWrapping="Wrap">
                                    <Run Text="{Binding Code, Mode=OneWay}"/>
                                    <Run Text=" - '"/>
                                    <Run Text="{Binding Name, Mode=OneWay}"/>
                                    <Run Text="'"/>
                                </TextBlock>
                                <TextBlock Text="{Binding Address}" FontSize="10" Foreground="#757575"
                                           TextWrapping="Wrap" Margin="0,3,0,0" MaxWidth="170"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Связь -->
                <DataGridTemplateColumn Header="Связь" Width="90">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Image Source="{Binding ConnectionDot}" Width="14" Height="14" Margin="0,0,3,0"/>
                                    <Image Source="{Binding OperatorIcon}" Width="24" Height="24" Margin="0,0,3,0"/>
                                    <Image Source="{Binding SignalIcon}" Width="22" Height="22"/>
                                </StackPanel>
                                <TextBlock Text="{Binding LoadInfo}" FontSize="9" Foreground="#757575"
                                           HorizontalAlignment="Center" Margin="0,3,0,0"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Загрузка (с прогресс-барами) -->
                <DataGridTemplateColumn Header="Загрузка" Width="140">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel VerticalAlignment="Center" Margin="6,4">
                                <!-- Общий процент загрузки -->
                                <Border CornerRadius="4" Padding="6,3" HorizontalAlignment="Left" Margin="0,0,0,4"
                                        Background="{Binding LoadBadgeColor, Converter={StaticResource ColorToBrushConverter}}">
                                    <StackPanel Orientation="Horizontal">
                                        <Image Source="/Assets/Icons/Other/Fillup.png" Width="14" Height="14" Margin="0,0,4,0"/>
                                        <TextBlock Text="{Binding LoadPercent, StringFormat={}{0}%}"
                                                   FontSize="12" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <!-- Прогресс-бары ингредиентов -->
                                <Grid Width="120">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <!-- Кофе -->
                                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,4,0">
                                        <ProgressBar Value="{Binding CoffeeLoad}" Maximum="100" Height="6"
                                                     Foreground="{Binding CoffeeLoadColor, Converter={StaticResource ColorToBrushConverter}}"
                                                     Background="#E0E0E0"/>
                                    </StackPanel>
                                    <!-- Сахар -->
                                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="4,0,0,0">
                                        <ProgressBar Value="{Binding SugarLoad}" Maximum="100" Height="6"
                                                     Foreground="{Binding SugarLoadColor, Converter={StaticResource ColorToBrushConverter}}"
                                                     Background="#E0E0E0"/>
                                    </StackPanel>
                                    <!-- Молоко -->
                                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,2,4,0">
                                        <ProgressBar Value="{Binding MilkLoad}" Maximum="100" Height="6"
                                                     Foreground="{Binding MilkLoadColor, Converter={StaticResource ColorToBrushConverter}}"
                                                     Background="#E0E0E0"/>
                                    </StackPanel>
                                    <!-- Стаканы -->
                                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="4,2,0,0">
                                        <ProgressBar Value="{Binding CupsLoad}" Maximum="100" Height="6"
                                                     Foreground="{Binding CupsLoadColor, Converter={StaticResource ColorToBrushConverter}}"
                                                     Background="#E0E0E0"/>
                                    </StackPanel>
                                    <!-- Крышки -->
                                    <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,2,4,0">
                                        <ProgressBar Value="{Binding LidsLoad}" Maximum="100" Height="6"
                                                     Foreground="{Binding LidsLoadColor, Converter={StaticResource ColorToBrushConverter}}"
                                                     Background="#E0E0E0"/>
                                    </StackPanel>
                                    <!-- Вода -->
                                    <StackPanel Grid.Row="2" Grid.Column="1" Margin="4,2,0,0">
                                        <ProgressBar Value="{Binding WaterLoad}" Maximum="100" Height="6"
                                                     Foreground="{Binding WaterLoadColor, Converter={StaticResource ColorToBrushConverter}}"
                                                     Background="#E0E0E0"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Денежные средства -->
                <DataGridTemplateColumn Header="Денежные средства" Width="140">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel VerticalAlignment="Center" Margin="6,2">
                                <!-- Купюры -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                                    <Image Source="/Assets/Icons/States/Bills.png" Width="16" Height="16" Margin="0,0,4,0"/>
                                    <TextBlock FontSize="11" VerticalAlignment="Center">
                                        <Run Text="{Binding CashAmount, StringFormat={}{0:N0}, Mode=OneWay}"/>
                                        <Run Text=" р."/>
                                    </TextBlock>
                                </StackPanel>
                                <!-- Монеты -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                                    <Image Source="/Assets/Icons/States/Coins.png" Width="16" Height="16" Margin="0,0,4,0"/>
                                    <TextBlock FontSize="11" VerticalAlignment="Center">
                                        <Run Text="{Binding CoinCount, Mode=OneWay}"/>
                                        <Run Text=" шт."/>
                                    </TextBlock>
                                </StackPanel>
                                <!-- Сдача -->
                                <StackPanel Orientation="Horizontal">
                                    <Image Source="/Assets/Icons/States/Change.png" Width="16" Height="16" Margin="0,0,4,0"/>
                                    <TextBlock FontSize="11" VerticalAlignment="Center">
                                        <Run Text="{Binding CoinAmount, StringFormat={}{0:N0}, Mode=OneWay}"/>
                                        <Run Text=" р."/>
                                    </TextBlock>
                                </StackPanel>
                                <!-- Последняя инкассация -->
                                <TextBlock FontSize="9" Foreground="#757575" Margin="0,3,0,0">
                                    <Run Text="o"/>
                                    <Run Text=" "/>
                                    <Run Text="{Binding LastEncashment, Mode=OneWay}"/>
                                </TextBlock>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- События -->
                <DataGridTemplateColumn Header="События" Width="90">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <!-- Продажи -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <Image Source="/Assets/Icons/States/Sale.png" Width="18" Height="18" Margin="0,0,4,0"/>
                                    <TextBlock Text="{Binding SalesCount}" FontSize="12" VerticalAlignment="Center"
                                               Foreground="#4CAF50" FontWeight="SemiBold"/>
                                </StackPanel>
                                <!-- Сервис -->
                                <StackPanel Orientation="Horizontal">
                                    <Image Source="/Assets/Icons/States/Service.png" Width="18" Height="18" Margin="0,0,4,0"/>
                                    <TextBlock Text="{Binding ServiceCount}" FontSize="12" VerticalAlignment="Center"
                                               Foreground="#FF9800" FontWeight="SemiBold"/>
                                </StackPanel>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Оборудование -->
                <DataGridTemplateColumn Header="Оборудование" Width="150">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <WrapPanel VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="145">
                                <Image Source="{Binding BillValidatorIcon}" Width="22" Height="22" Margin="2"
                                       ToolTip="Купюроприемник"/>
                                <Image Source="{Binding CoinAcceptorIcon}" Width="22" Height="22" Margin="2"
                                       ToolTip="Монетоприемник"/>
                                <Image Source="{Binding CashlessIcon}" Width="22" Height="22" Margin="2"
                                       ToolTip="Безнал"/>
                                <Image Source="{Binding CashRegisterIcon}" Width="22" Height="22" Margin="2"
                                       ToolTip="Кассовый аппарат"/>
                                <Image Source="{Binding DisplayIcon}" Width="22" Height="22" Margin="2"
                                       ToolTip="Дисплей"/>
                                <Image Source="{Binding PowerIcon}" Width="22" Height="22" Margin="2"
                                       ToolTip="Питание"/>
                            </WrapPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Информация -->
                <DataGridTemplateColumn Header="Информация" Width="110">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="4">
                                <!-- Статусные иконки -->
                                <WrapPanel HorizontalAlignment="Center" Margin="0,0,0,4">
                                    <Image Source="{Binding FewGoodsIcon}" Width="18" Height="18" Margin="1"
                                           Visibility="{Binding HasLowGoods, Converter={StaticResource BoolToVisibilityConverter}}"
                                           ToolTip="Мало товара"/>
                                    <Image Source="{Binding FewChangeIcon}" Width="18" Height="18" Margin="1"
                                           Visibility="{Binding HasFewChange, Converter={StaticResource BoolToVisibilityConverter}}"
                                           ToolTip="Мало сдачи"/>
                                    <Image Source="{Binding NoEncashmentIcon}" Width="18" Height="18" Margin="1"
                                           Visibility="{Binding NeedsEncashment, Converter={StaticResource BoolToVisibilityConverter}}"
                                           ToolTip="Нужна инкассация"/>
                                    <Image Source="{Binding NoServiceIcon}" Width="18" Height="18" Margin="1"
                                           Visibility="{Binding NeedsService, Converter={StaticResource BoolToVisibilityConverter}}"
                                           ToolTip="Нужно обслуживание"/>
                                </WrapPanel>
                                <TextBlock Text="{Binding LastActivity}"
                                           FontSize="10"
                                           Foreground="#757575"
                                           TextWrapping="Wrap"
                                           TextAlignment="Center"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Доп. -->
                <DataGridTemplateColumn Header="Доп." Width="85">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                                <!-- Иконки проблем -->
                                <Image Source="{Binding HardwareProblemsIcon}" Width="20" Height="20" Margin="2"
                                       Visibility="{Binding HasProblems, Converter={StaticResource BoolToVisibilityConverter}}"
                                       ToolTip="Проблемы с оборудованием"/>
                                <Image Source="{Binding NoSalesIcon}" Width="20" Height="20" Margin="2"
                                       Visibility="{Binding NoSales, Converter={StaticResource BoolToVisibilityConverter}}"
                                       ToolTip="Нет продаж"/>
                                <Image Source="{Binding DifferentSettingsIcon}" Width="20" Height="20" Margin="2"
                                       Visibility="{Binding HasDifferentSettings, Converter={StaticResource BoolToVisibilityConverter}}"
                                       ToolTip="Различные настройки"/>
                                <!-- Кнопки действий -->
                                <Button Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="2" ToolTip="Команды">
                                    <Image Source="/Assets/Icons/Other/Commands.png" Width="20" Height="20"/>
                                </Button>
                                <Button Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="2" ToolTip="Подробности">
                                    <Image Source="/Assets/Icons/Other/Details.png" Width="20" Height="20"/>
                                </Button>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Footer -->
        <Border Grid.Row="5" Background="#F8F9FA" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0" Padding="15,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" VerticalAlignment="Center" FontSize="12">
                    <Run Text="Итого автоматов:"/>
                    <Run Text=" "/>
                    <Run Text="{Binding TotalMachines, FallbackValue=0}" FontWeight="SemiBold"/>
                    <Run Text=" / "/>
                    <Run Text="{Binding OnlineMachines, FallbackValue=0}" Foreground="#4CAF50" FontWeight="SemiBold"/>
                    <Run Text=" / "/>
                    <Run Text="{Binding OfflineMachines, FallbackValue=0}" Foreground="#F44336" FontWeight="SemiBold"/>
                    <Run Text=". Денег в автоматах:"/>
                    <Run Text=" "/>
                    <Run Text="{Binding TotalCash, StringFormat={}{0:N0}р, FallbackValue=0р}" FontWeight="SemiBold"/>
                    <Run Text=" (сдача)"/>
                </TextBlock>

                <Button Grid.Column="1"
                        Command="{Binding ExportCommand}"
                        Background="#28A745"
                        Foreground="White"
                        Padding="20,8"
                        FontSize="12"
                        BorderThickness="0"
                        Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                               VerticalAlignment="Center" Margin="0,0,6,0" Foreground="White"/>
                                    <TextBlock Text="Экспорт в Excel" Foreground="White"/>
                                </StackPanel>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Page>
