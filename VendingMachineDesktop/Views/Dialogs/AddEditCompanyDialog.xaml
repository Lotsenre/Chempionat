<Window x:Class="VendingMachineDesktop.Views.Dialogs.AddEditCompanyDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Компания"
        Height="320"
        Width="900"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F5F5F5">

    <Window.Resources>
        <!-- Style for input TextBox -->
        <Style x:Key="InputTextBox" TargetType="TextBox">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#CED4DA"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Style for ComboBox -->
        <Style x:Key="InputComboBox" TargetType="ComboBox">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#CED4DA"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
        </Style>

        <!-- Primary Button Style -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="MinWidth" Value="100"/>
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="#17A2B8"
                                BorderBrush="#17A2B8"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              TextBlock.Foreground="White"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#138496"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#117A8B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Secondary Button Style -->
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="MinWidth" Value="100"/>
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="White"
                                BorderBrush="#CED4DA"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              TextBlock.Foreground="#333333"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#F8F9FA"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E9ECEF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Row 1: Вышестоящая компания, Название компании, Адрес компании -->
        <Grid Grid.Row="0" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Вышестоящая компания -->
            <StackPanel Grid.Column="0">
                <TextBlock Margin="0,0,0,5">
                    <Run Text="Вышестоящая компания" Foreground="#333"/>
                    <Run Text=" *" Foreground="#DC3545"/>
                </TextBlock>
                <ComboBox ItemsSource="{Binding ParentCompanies}"
                          SelectedItem="{Binding SelectedParentCompany}"
                          DisplayMemberPath="Name"
                          Style="{StaticResource InputComboBox}"/>
            </StackPanel>

            <!-- Название компании -->
            <StackPanel Grid.Column="2">
                <TextBlock Margin="0,0,0,5">
                    <Run Text="Название компании" Foreground="#333"/>
                    <Run Text=" *" Foreground="#DC3545"/>
                </TextBlock>
                <TextBox Text="{Binding CompanyName, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource InputTextBox}"/>
            </StackPanel>

            <!-- Адрес компании -->
            <StackPanel Grid.Column="4">
                <TextBlock Margin="0,0,0,5">
                    <Run Text="Адрес компании" Foreground="#333"/>
                    <Run Text=" *" Foreground="#DC3545"/>
                </TextBlock>
                <TextBox Text="{Binding CompanyAddress, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource InputTextBox}"/>
            </StackPanel>
        </Grid>

        <!-- Row 2: Контакты компании, Примечания -->
        <Grid Grid.Row="1" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <!-- Контакты компании -->
            <StackPanel Grid.Column="0">
                <TextBlock Margin="0,0,0,5">
                    <Run Text="Контакты компании" Foreground="#333"/>
                    <Run Text=" *" Foreground="#DC3545"/>
                </TextBlock>
                <TextBox Text="{Binding CompanyContacts, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource InputTextBox}"/>
            </StackPanel>

            <!-- Примечания -->
            <StackPanel Grid.Column="2">
                <TextBlock Text="Примечания" Foreground="#333" Margin="0,0,0,5"/>
                <TextBox Text="{Binding CompanyNotes, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         Height="70"
                         Background="White"
                         BorderBrush="#CED4DA"
                         BorderThickness="1"
                         Padding="10,8">
                    <TextBox.Template>
                        <ControlTemplate TargetType="TextBox">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="4">
                                <ScrollViewer x:Name="PART_ContentHost"
                                              Margin="{TemplateBinding Padding}"/>
                            </Border>
                        </ControlTemplate>
                    </TextBox.Template>
                </TextBox>
            </StackPanel>
        </Grid>

        <!-- Spacer -->
        <Grid Grid.Row="2"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,10,0,0">
            <Button Content="{Binding ButtonText}"
                    Command="{Binding SaveCommand}"
                    Style="{StaticResource PrimaryButton}"
                    Margin="0,0,10,0"/>
            <Button Content="Отменить"
                    Command="{Binding CancelCommand}"
                    Style="{StaticResource SecondaryButton}"/>
        </StackPanel>
    </Grid>
</Window>
