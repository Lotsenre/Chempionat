<Window x:Class="VendingMachineDesktop.Views.Dialogs.AddEditContractDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="{Binding DialogTitle}"
        Height="420" Width="900"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F5F5F5">

    <Window.Resources>
        <Style x:Key="InputTextBox" TargetType="TextBox">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#CED4DA"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="InputComboBox" TargetType="ComboBox">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#CED4DA"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
        </Style>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="MinWidth" Value="100"/>
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="#17A2B8" BorderBrush="#17A2B8" BorderThickness="1" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" TextBlock.Foreground="White"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="border" Property="Background" Value="#138496"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="MinWidth" Value="100"/>
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="White" BorderBrush="#CED4DA" BorderThickness="1" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" TextBlock.Foreground="#333333"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="border" Property="Background" Value="#F8F9FA"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Row 1: Номер контракта, Компания, Автомат -->
        <Grid Grid.Row="0" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="Номер контракта" Foreground="#333" Margin="0,0,0,5"/>
                <TextBox Text="{Binding ContractNumber, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBox}"/>
            </StackPanel>

            <StackPanel Grid.Column="2">
                <TextBlock Text="Компания" Foreground="#333" Margin="0,0,0,5"/>
                <ComboBox ItemsSource="{Binding Companies}" SelectedItem="{Binding SelectedCompany}"
                          DisplayMemberPath="Name" Style="{StaticResource InputComboBox}"/>
            </StackPanel>

            <StackPanel Grid.Column="4">
                <TextBlock Margin="0,0,0,5"><Run Text="Торговый автомат" Foreground="#333"/><Run Text=" *" Foreground="#DC3545"/></TextBlock>
                <ComboBox ItemsSource="{Binding VendingMachines}" SelectedItem="{Binding SelectedVendingMachine}"
                          DisplayMemberPath="Name" Style="{StaticResource InputComboBox}"/>
            </StackPanel>
        </Grid>

        <!-- Row 2: Даты, Аренда -->
        <Grid Grid.Row="1" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="Дата начала" Foreground="#333" Margin="0,0,0,5"/>
                <DatePicker SelectedDate="{Binding StartDate}" Style="{StaticResource WhiteOutlinedDatePicker}"/>
            </StackPanel>

            <StackPanel Grid.Column="2">
                <TextBlock Text="Дата окончания" Foreground="#333" Margin="0,0,0,5"/>
                <DatePicker SelectedDate="{Binding EndDate}" Style="{StaticResource WhiteOutlinedDatePicker}"/>
            </StackPanel>

            <StackPanel Grid.Column="4">
                <TextBlock Text="Аренда/мес" Foreground="#333" Margin="0,0,0,5"/>
                <TextBox Text="{Binding MonthlyRent, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBox}"/>
            </StackPanel>

            <StackPanel Grid.Column="6">
                <TextBlock Text="Аренда/год" Foreground="#333" Margin="0,0,0,5"/>
                <TextBox Text="{Binding YearlyRent, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputTextBox}"/>
            </StackPanel>
        </Grid>

        <!-- Row 3: Тип управления, Страховка -->
        <Grid Grid.Row="2" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="Тип управления" Foreground="#333" Margin="0,0,0,5"/>
                <ComboBox ItemsSource="{Binding ManagementTypes}" SelectedItem="{Binding ManagementType}" Style="{StaticResource InputComboBox}"/>
            </StackPanel>

            <StackPanel Grid.Column="2" VerticalAlignment="Bottom">
                <CheckBox Content="Требуется страхование" IsChecked="{Binding InsuranceRequired}"
                          Style="{StaticResource MaterialDesignCheckBox}" Margin="0,0,0,10"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="3"/>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,10,0,0">
            <Button Content="{Binding ButtonText}" Command="{Binding SaveCommand}" Style="{StaticResource PrimaryButton}" Margin="0,0,10,0"/>
            <Button Content="Отменить" Command="{Binding CancelCommand}" Style="{StaticResource SecondaryButton}"/>
        </StackPanel>
    </Grid>
</Window>
