<Window x:Class="VendingMachineDesktop.Views.Dialogs.AddEditVendingMachineDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="{Binding DialogTitle}"
        Height="750"
        Width="900"
        MinHeight="700"
        MinWidth="850"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="13"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="Auto"
        FontFamily="{DynamicResource MaterialDesignFont}">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <materialDesign:BundledTheme x:Name="BundledTheme" BaseTheme="Light" PrimaryColor="Blue" SecondaryColor="LightBlue" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign3.Defaults.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <!-- Header -->
        <Border Background="#2196F3" Height="60" VerticalAlignment="Top">
            <TextBlock Text="{Binding DialogTitle}"
                       FontSize="20"
                       FontWeight="SemiBold"
                       Foreground="White"
                       VerticalAlignment="Center"
                       Margin="24,0"/>
        </Border>

        <!-- Content -->
        <materialDesign:Card Margin="20,80,20,20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Form -->
                <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Padding="24,20">
                    <StackPanel>
                        <!-- Row 1: Название ТА, Производитель ТА, Модель ТА -->
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Название ТА *" FontSize="12" Foreground="#757575" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding Machine.Name, UpdateSourceTrigger=PropertyChanged}"
                                         materialDesign:HintAssist.Hint="Введите название"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Производитель ТА *" FontSize="12" Foreground="#757575" Margin="0,0,0,4"/>
                                <ComboBox ItemsSource="{Binding Manufacturers}"
                                          SelectedItem="{Binding SelectedManufacturer}"
                                          materialDesign:HintAssist.Hint="Выберите"
                                          Style="{StaticResource MaterialDesignComboBox}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="4">
                                <TextBlock Text="Модель ТА *" FontSize="12" Foreground="#757575" Margin="0,0,0,4"/>
                                <ComboBox ItemsSource="{Binding Models}"
                                          SelectedItem="{Binding SelectedModel}"
                                          materialDesign:HintAssist.Hint="Выберите"
                                          Style="{StaticResource MaterialDesignComboBox}"/>
                            </StackPanel>
                        </Grid>

                        <!-- Row 2: Режим работы, Производитель ТА (Slave), Модель ТА (Slave) -->
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Режим работы *" FontSize="12" Foreground="#757575" Margin="0,0,0,4"/>
                                <ComboBox ItemsSource="{Binding WorkModes}"
                                          SelectedItem="{Binding Machine.WorkMode}"
                                          materialDesign:HintAssist.Hint="Выберите"
                                          Style="{StaticResource MaterialDesignComboBox}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Производитель ТА (Slave)" FontSize="12" Foreground="#757575" Margin="0,0,0,4"/>
                                <ComboBox ItemsSource="{Binding ManufacturersSlave}"
                                          SelectedItem="{Binding SelectedManufacturerSlave}"
                                          materialDesign:HintAssist.Hint="Выберите"
                                          Style="{StaticResource MaterialDesignComboBox}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="4">
                                <TextBlock Text="Модель ТА (Slave)" FontSize="12" Foreground="#757575" Margin="0,0,0,4"/>
                                <ComboBox ItemsSource="{Binding ModelsSlave}"
                                          SelectedItem="{Binding SelectedModelSlave}"
                                          materialDesign:HintAssist.Hint="Выберите"
                                          Style="{StaticResource MaterialDesignComboBox}"/>
                            </StackPanel>
                        </Grid>

                        <!-- Row 3: Адрес, Место, Координаты -->
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Адрес *" FontSize="12" Foreground="#757575" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding Machine.Location, UpdateSourceTrigger=PropertyChanged}"
                                         materialDesign:HintAssist.Hint="Введите адрес"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Место *" FontSize="12" Foreground="#757575" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding Machine.Place, UpdateSourceTrigger=PropertyChanged}"
                                         materialDesign:HintAssist.Hint="Введите место"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="4">
                                <TextBlock Text="Координаты" FontSize="12" Foreground="#757575" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding Machine.Coordinates, UpdateSourceTrigger=PropertyChanged}"
                                         materialDesign:HintAssist.Hint="Широта, Долгота"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                            </StackPanel>
                        </Grid>

                        <!-- Row 4: Номер автомата, Время работы, Часовой пояс -->
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Номер автомата *" FontSize="12" Foreground="#757575" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding Machine.SerialNumber, UpdateSourceTrigger=PropertyChanged}"
                                         materialDesign:HintAssist.Hint="Введите номер"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Время работы" FontSize="12" Foreground="#757575" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding Machine.WorkingHours, UpdateSourceTrigger=PropertyChanged}"
                                         materialDesign:HintAssist.Hint="08:00-22:00"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="4">
                                <TextBlock Text="Часовой пояс *" FontSize="12" Foreground="#757575" Margin="0,0,0,4"/>
                                <ComboBox ItemsSource="{Binding Timezones}"
                                          SelectedItem="{Binding Machine.Timezone}"
                                          materialDesign:HintAssist.Hint="Выберите"
                                          Style="{StaticResource MaterialDesignComboBox}"/>
                            </StackPanel>
                        </Grid>

                        <!-- Row 5: Товарная матрица, Шаблон крит. значений, Шаблон уведомлений -->
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Товарная матрица *" FontSize="12" Foreground="#757575" Margin="0,0,0,4"/>
                                <ComboBox ItemsSource="{Binding ProductMatrices}"
                                          SelectedItem="{Binding Machine.ProductMatrix}"
                                          materialDesign:HintAssist.Hint="Выберите"
                                          Style="{StaticResource MaterialDesignComboBox}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Шаблон крит. значений" FontSize="12" Foreground="#757575" Margin="0,0,0,4"/>
                                <ComboBox ItemsSource="{Binding CriticalThresholdTemplates}"
                                          SelectedItem="{Binding Machine.CriticalThresholdTemplate}"
                                          materialDesign:HintAssist.Hint="Выберите"
                                          Style="{StaticResource MaterialDesignComboBox}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="4">
                                <TextBlock Text="Шаблон уведомлений" FontSize="12" Foreground="#757575" Margin="0,0,0,4"/>
                                <ComboBox ItemsSource="{Binding NotificationTemplates}"
                                          SelectedItem="{Binding Machine.NotificationTemplate}"
                                          materialDesign:HintAssist.Hint="Выберите"
                                          Style="{StaticResource MaterialDesignComboBox}"/>
                            </StackPanel>
                        </Grid>

                        <!-- Row 6: Клиент, Менеджер, Инженер -->
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Клиент" FontSize="12" Foreground="#757575" Margin="0,0,0,4"/>
                                <ComboBox ItemsSource="{Binding Clients}"
                                          SelectedItem="{Binding Machine.Client}"
                                          materialDesign:HintAssist.Hint="Выберите"
                                          Style="{StaticResource MaterialDesignComboBox}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Менеджер" FontSize="12" Foreground="#757575" Margin="0,0,0,4"/>
                                <ComboBox ItemsSource="{Binding Managers}"
                                          SelectedItem="{Binding Machine.Manager}"
                                          materialDesign:HintAssist.Hint="Выберите"
                                          Style="{StaticResource MaterialDesignComboBox}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="4">
                                <TextBlock Text="Инженер" FontSize="12" Foreground="#757575" Margin="0,0,0,4"/>
                                <ComboBox ItemsSource="{Binding Engineers}"
                                          SelectedItem="{Binding Machine.Engineer}"
                                          materialDesign:HintAssist.Hint="Выберите"
                                          Style="{StaticResource MaterialDesignComboBox}"/>
                            </StackPanel>
                        </Grid>

                        <!-- Row 7: Техник-оператор, Платежные системы -->
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="2*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Техник-оператор" FontSize="12" Foreground="#757575" Margin="0,0,0,4"/>
                                <ComboBox ItemsSource="{Binding Operators}"
                                          SelectedItem="{Binding Machine.Operator}"
                                          materialDesign:HintAssist.Hint="Выберите"
                                          Style="{StaticResource MaterialDesignComboBox}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Платежные системы *" FontSize="12" Foreground="#757575" Margin="0,0,0,4"/>
                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                    <CheckBox Content="Монетопр."
                                              IsChecked="{Binding Machine.HasCoinAcceptor}"
                                              Style="{StaticResource MaterialDesignCheckBox}"
                                              Margin="0,0,20,0"/>
                                    <CheckBox Content="Купюропр."
                                              IsChecked="{Binding Machine.HasBillAcceptor}"
                                              Style="{StaticResource MaterialDesignCheckBox}"
                                              Margin="0,0,20,0"/>
                                    <CheckBox Content="Модуль б/н опл."
                                              IsChecked="{Binding Machine.HasCashlessModule}"
                                              Style="{StaticResource MaterialDesignCheckBox}"
                                              Margin="0,0,20,0"/>
                                    <CheckBox Content="QR-платежи"
                                              IsChecked="{Binding Machine.HasQrPayment}"
                                              Style="{StaticResource MaterialDesignCheckBox}"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>

                        <!-- Row 8: RFID карты -->
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="RFID карты обслуживания" FontSize="12" Foreground="#757575" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding Machine.RfidService, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="RFID карты инкассации" FontSize="12" Foreground="#757575" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding Machine.RfidCashCollection, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="4">
                                <TextBlock Text="RFID карты загрузки" FontSize="12" Foreground="#757575" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding Machine.RfidLoading, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                            </StackPanel>
                        </Grid>

                        <!-- Row 9: Id кассы Kit Online, Приоритет обслуживания, Модем -->
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Id кассы Kit Online" FontSize="12" Foreground="#757575" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding Machine.KitOnlineId, UpdateSourceTrigger=PropertyChanged}"
                                         materialDesign:HintAssist.Hint="Только при жёсткой привязке"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Приоритет обслуживания *" FontSize="12" Foreground="#757575" Margin="0,0,0,4"/>
                                <ComboBox ItemsSource="{Binding ServicePriorities}"
                                          SelectedItem="{Binding Machine.ServicePriority}"
                                          materialDesign:HintAssist.Hint="Выберите"
                                          Style="{StaticResource MaterialDesignComboBox}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="4">
                                <TextBlock Text="Модем *" FontSize="12" Foreground="#757575" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding Machine.ModemNumber, UpdateSourceTrigger=PropertyChanged}"
                                         materialDesign:HintAssist.Hint="Номер модема"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                            </StackPanel>
                        </Grid>

                        <!-- Row 10: Примечания -->
                        <StackPanel Margin="0,0,0,16">
                            <TextBlock Text="Примечания" FontSize="12" Foreground="#757575" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding Machine.Notes, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     MinHeight="80"
                                     MaxHeight="120"
                                     VerticalScrollBarVisibility="Auto"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>

                <!-- Actions -->
                <Border Grid.Row="1" BorderThickness="0,1,0,0" BorderBrush="#E0E0E0" Padding="24,16">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <Button Content="{Binding SaveButtonText}"
                                Command="{Binding SaveCommand}"
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                Background="#2196F3"
                                Foreground="White"
                                Width="120"
                                Height="36"
                                Margin="0,0,12,0"/>
                        <Button Content="Отменить"
                                Command="{Binding CancelCommand}"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Width="100"
                                Height="36"
                                Visibility="{Binding ShowCancelButton, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </materialDesign:Card>
    </Grid>
</Window>
